# Casa del Pollo Website — contact form + mailing list signup
# Copy to .env (never commit secrets) and fill in production-ready values.
#
# Mailing list (`mailing-list-signup.php`) inserts into the same MySQL table as
# the campaign console (`CUSTOMERS` by default). Use the same DB_* values as
# apps/campaign_console/.env and apps/unsubscribe_service. The DB user must
# have INSERT (and SELECT) on that table; grant INSERT if the user was created
# only for the unsubscribe app (UPDATE-only is not enough for signups).

EMAIL_USER=marketing@example.com
EMAIL_PASSWORD=replace-with-smtp-password
FROM_EMAIL=contact@example.com
FROM_NAME="Casa del Pollo"
FORM_RECIPIENT=contact@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
RECAPTCHA_SECRET_KEY=replace-with-recaptcha-secret

# MySQL — mailing list signup (omit if not using signup locally)
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASS=replace-with-db-password
DB_NAME=your_database
# Physical table name (must match campaign console / unsubscribe)
DB_CUSTOMER_TABLE=CUSTOMERS
